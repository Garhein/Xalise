<!doctype html>
<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Xalise - @ViewData["Title"]</title>
        <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/font-awesome/css/all.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    </head>
    <body>
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <span class="d-block d-sm-none"><a asp-area="GestionProjet" asp-controller="ListeProjets" asp-action="Index" class="navbar-brand">Xalise.Web.XS</a></span>
                    <span class="d-none d-sm-block d-md-none"><a asp-area="GestionProjet" asp-controller="ListeProjets" asp-action="Index" class="navbar-brand">Xalise.Web.SM</a></span>
                    <span class="d-none d-md-block d-lg-none"><a asp-area="GestionProjet" asp-controller="ListeProjets" asp-action="Index" class="navbar-brand">Xalise.Web.MD</a></span>
                    <span class="d-none d-lg-block d-xl-none"><a asp-area="GestionProjet" asp-controller="ListeProjets" asp-action="Index" class="navbar-brand">Xalise.Web.LG</a></span>
                    <span class="d-none d-xl-block d-xxl-none"><a asp-area="GestionProjet" asp-controller="ListeProjets" asp-action="Index" class="navbar-brand">Xalise.Web.XL</a></span>
                    <span class="d-none d-xxl-block"><a asp-area="GestionProjet" asp-controller="ListeProjets" asp-action="Index" class="navbar-brand">Xalise.Web.XXL</a></span>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="GestionProjet" asp-controller="ListeProjets" asp-action="Index">Projets</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="container-fluid pb-3">
            <div class="row">
                <div class="col-sm-12 offset-sm-0 col-md-10 offset-md-1">
                    @RenderBody()
                </div>
            </div>
        </main>
        
        <footer class="border-top footer text-muted">
            <div class="container-fluid">
                &copy; 2024 - Xalise.Web
            </div>
        </footer>

        <script src="~/lib/jquery/jquery.min.js"></script>
        <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
        <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>
